{
  "$schema": "http://json-schema.org/schema#",
  "$id": "https://raw.githubusercontent.com/cagov/Cron/master/common/SQL/CDTCDPH_VACCINE/vaccines_by_race_ethnicity/schema/input/schema.json",
  "type": "array",
  "uniqueItems": true,
  
  "items": {
    "type": "object",
    "required": [
      "LATEST_ADMIN_DATE",
      "REGION",
      "CATEGORY",
      "METRIC_VALUE"
    ],
    "additionalProperties": false,
    "properties": {
      "LATEST_ADMIN_DATE": {
        "$ref": "#/definitions/date-YYYY-MM-DD"
      },
      "REGION": {
        "type": "string",
        "$ref": "#/definitions/region-california-counties"
      },
      "CATEGORY": {
        "type": "string",
        "type": "string",
        "enum": [
          "Female",
          "Male",
          "Unknown/undifferentiated"
        ]
      },
      "METRIC_VALUE": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    }
  },
  "definitions": {
    "date-YYYY-MM-DD": {
      "type": "string",
      "pattern": "^\\d{4}-(?:0[0-9]{1}|1[0-2]{1})-(3[01]|0[1-9]|[12][0-9])$"
    },
    "categories-gender": {
      "type": "string",
      "enum": [  
        "Female",
        "Male",
        "Unknown/undifferentiated"
      ]
    },
    "region-california-counties": {
      "type": "string",
      "minLength": 2,
      "maxLength": 60,
